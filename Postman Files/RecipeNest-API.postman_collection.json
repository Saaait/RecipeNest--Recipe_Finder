							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"updatedusername\",\n    \"email\": \"updated@example.com\"\n}"
						},
						"url": {
							"raw": "{{baseURL}}/api/users/:id",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"api",
								"users",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "USER_ID_HERE"
								}
							]
						}
